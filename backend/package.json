{
  "name": "stellar-greenpay-backend",
  "version": "1.0.0",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "dev:docker": "nodemon --legacy-watch --watch src src/server.js",
    "start": "node src/server.js",
    "db:migrate": "node src/db/migrate.js",
    "db:rollback": "node src/db/migrate.js --rollback",
    "db:rollback:n": "node src/db/migrate.js --rollback",
    "lint": "eslint src/**/*.js",
    "docs": "typedoc --options typedoc.json",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@stellar/stellar-sdk": "^12.0.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^16.4.5",
    "expo-server-sdk": "^5.0.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "iconv-lite": "^0.7.2",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "pg": "^8.20.0",
    "pg-boss": "^10.1.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "6.2.8",
    "swagger-ui-express": "5.0.1",
    "uuid": "^10.0.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-plugin-security": "^1.7.1",
    "eslint-plugin-sql-injection": "^1.0.1",
    "jest": "^30.3.0",
    "nodemon": "^3.1.2",
    "pino-pretty": "^13.1.3",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.0.0",
    "typedoc": "^0.28.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
