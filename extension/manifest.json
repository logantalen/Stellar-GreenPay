{
  "manifest_version": 3,
  "name": "GreenPay Companion",
  "version": "1.0.0",
  "description": "Support your favorite sustainable projects with a single click.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "GreenPay Companion"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://app.greenpay.io/*",
    "https://testnet.greenpay.io/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://app.greenpay.io/*", "https://testnet.greenpay.io/*"],
      "js": ["dist/content-script.js"],
      "run_at": "document_end"
    }
  ],
  "privacy_policy_url": "https://github.com/Emmy123222/Stellar-GreenPay/blob/main/PRIVACY.md"
}
